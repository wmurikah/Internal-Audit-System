// Run warmAllCachesOnDeploy() after deploying or when performance degrades

/**
 * Main getPermissions function - called by other services
 * Uses short cache TTL to ensure permission changes propagate quickly
 */
function getPermissions(roleCode, forceFresh) {
  if (!roleCode) return {};
  
  if (forceFresh === true) {
    return getPermissionsFresh(roleCode);
  }
  
  const cache = CacheService.getScriptCache();
  const cacheKey = 'perm_' + roleCode;
  
  try {
    const cached = cache.get(cacheKey);
    if (cached) {
      const parsed = JSON.parse(cached);
      if (Object.keys(parsed).length > 0) {
        return parsed;
      }
    }
  } catch (e) {
    console.warn('Cache read failed for permissions:', e);
  }
  
  const permissions = getPermissionsFresh(roleCode);
  
  try {
    if (Object.keys(permissions).length > 0) {
      cache.put(cacheKey, JSON.stringify(permissions), 300);
    }
  } catch (e) {
    console.warn('Failed to cache permissions:', e);
  }
  
  return permissions;
}

/**
 * Check if a role has permission for a specific action on a module
 */
function checkPermission(roleCode, module, action) {
  if (!roleCode || !module || !action) return false;
  
  const permissions = getPermissions(roleCode);
  
  const actionMap = {
    'create': 'can_create',
    'read': 'can_read',
    'update': 'can_update',
    'delete': 'can_delete',
    'approve': 'can_approve',
    'export': 'can_export'
  };
  
  const permField = actionMap[action.toLowerCase()];
  if (!permField) return false;
  
  if (permissions[module] && permissions[module][permField] === true) {
    return true;
  }
  
  return false;
}

/**
 * Master cache warm function - call after deployment or when caches are cold
 */
function warmAllCachesOnDeploy() {
  const startTime = new Date().getTime();
  console.log('=== CACHE WARMING STARTED ===');
  
  const cache = CacheService.getScriptCache();
  const results = { success: true, cached: [], errors: [], duration: 0 };
  
  // 1. Warm dropdown data
  console.log('[1/4] Caching dropdown data...');
  try {
    const dropdownStart = new Date().getTime();
    const dropdowns = getDropdownDataFresh();
    cache.put('dropdown_data_all', JSON.stringify(dropdowns), 1800);
    results.cached.push('dropdowns (' + (new Date().getTime() - dropdownStart) + 'ms)');
  } catch (e) {
    results.errors.push('dropdowns: ' + e.message);
  }
  
  // 2. Warm role permissions
  console.log('[2/4] Caching role permissions...');
  const roles = ['SUPER_ADMIN', 'SENIOR_AUDITOR', 'JUNIOR_STAFF', 'AUDITEE', 'MANAGEMENT', 'SENIOR_MGMT'];
  try {
    const permStart = new Date().getTime();
    roles.forEach(role => {
      const perms = getPermissionsFresh(role);
      cache.put('perm_' + role, JSON.stringify(perms), CONFIG.CACHE_TTL.PERMISSIONS);
    });
    results.cached.push('permissions (' + (new Date().getTime() - permStart) + 'ms)');
  } catch (e) {
    results.errors.push('permissions: ' + e.message);
  }
  
  // 3. Warm role names
  console.log('[3/4] Caching role names...');
  try {
    const roleStart = new Date().getTime();
    roles.forEach(role => {
      const name = getRoleNameFresh(role);
      cache.put('role_name_' + role, name || role, 3600);
    });
    results.cached.push('roleNames (' + (new Date().getTime() - roleStart) + 'ms)');
  } catch (e) {
    results.errors.push('roleNames: ' + e.message);
  }
  
  // 4. Warm config values
  console.log('[4/4] Caching config values...');
  const configKeys = ['SYSTEM_NAME', 'SESSION_TIMEOUT_HOURS', 'PASSWORD_MIN_LENGTH', 'MAX_LOGIN_ATTEMPTS', 'AUDIT_FILES_FOLDER_ID'];
  try {
    const configStart = new Date().getTime();
    configKeys.forEach(key => {
      const value = getConfigValueFresh(key);
      if (value) cache.put('config_' + key, String(value), 3600);
    });
    results.cached.push('config (' + (new Date().getTime() - configStart) + 'ms)');
  } catch (e) {
    results.errors.push('config: ' + e.message);
  }
  
  results.duration = new Date().getTime() - startTime;
  console.log('=== CACHE WARMING COMPLETE === Duration:', results.duration, 'ms');
  return results;
}

/**
 * Get dropdown data fresh from Firestore (bypasses cache)
 */
function getDropdownDataFresh() {
  const dropdowns = { affiliates: [], auditAreas: [], subAreas: [], users: [], roles: [] };
  
  try {
    var affData = getSheetData(SHEETS.AFFILIATES);
    if (affData && affData.length > 1) {
      var affHeaders = affData[0];
      var codeIdx = affHeaders.indexOf('affiliate_code');
      var nameIdx = affHeaders.indexOf('affiliate_name');
      var activeIdx = affHeaders.indexOf('is_active');
      for (var i = 1; i < affData.length; i++) {
        if (isActive(affData[i][activeIdx])) {
          dropdowns.affiliates.push({ code: affData[i][codeIdx], name: affData[i][nameIdx] });
        }
      }
    }
  } catch (e) { console.warn('Failed to load affiliates:', e); }
  
  try {
    var areaData = getSheetData(SHEETS.AUDIT_AREAS);
    if (areaData && areaData.length > 1) {
      var areaHeaders = areaData[0];
      var idIdx = areaHeaders.indexOf('area_id');
      if (idIdx === -1) idIdx = areaHeaders.indexOf('audit_area_id');
      var areaNameIdx = areaHeaders.indexOf('area_name');
      if (areaNameIdx === -1) areaNameIdx = areaHeaders.indexOf('audit_area_name');
      var areaActiveIdx = areaHeaders.indexOf('is_active');
      for (var i = 1; i < areaData.length; i++) {
        if (isActive(areaData[i][areaActiveIdx])) {
          dropdowns.auditAreas.push({ id: areaData[i][idIdx], name: areaData[i][areaNameIdx] });
        }
      }
    }
  } catch (e) { console.warn('Failed to load audit areas:', e); }
  
  try {
    var subData = getSheetData(SHEETS.SUB_AREAS);
    if (subData && subData.length > 1) {
      var subHeaders = subData[0];
      var subIdIdx = subHeaders.indexOf('sub_area_id');
      var subNameIdx = subHeaders.indexOf('sub_area_name');
      var parentIdx = subHeaders.indexOf('area_id');
      var subActiveIdx = subHeaders.indexOf('is_active');
      for (var i = 1; i < subData.length; i++) {
        if (isActive(subData[i][subActiveIdx])) {
          dropdowns.subAreas.push({ id: subData[i][subIdIdx], name: subData[i][subNameIdx], parentId: subData[i][parentIdx] });
        }
      }
    }
  } catch (e) { console.warn('Failed to load sub areas:', e); }
  
  try {
    var userData = getSheetData(SHEETS.USERS);
    if (userData && userData.length > 1) {
      var userHeaders = userData[0];
      var userIdIdx = userHeaders.indexOf('user_id');
      var userNameIdx = userHeaders.indexOf('full_name');
      var emailIdx = userHeaders.indexOf('email');
      var roleIdx = userHeaders.indexOf('role_code');
      var userActiveIdx = userHeaders.indexOf('is_active');
      for (var i = 1; i < userData.length; i++) {
        if (isActive(userData[i][userActiveIdx])) {
          dropdowns.users.push({ id: userData[i][userIdIdx], name: userData[i][userNameIdx], email: userData[i][emailIdx], roleCode: userData[i][roleIdx] });
        }
      }
    }
  } catch (e) { console.warn('Failed to load users:', e); }
  
  try {
    var roleData = getSheetData(SHEETS.ROLES);
    if (roleData && roleData.length > 1) {
      var roleHeaders = roleData[0];
      var roleCodeIdx = roleHeaders.indexOf('role_code');
      var roleNameIdx = roleHeaders.indexOf('role_name');
      var roleActiveIdx = roleHeaders.indexOf('is_active');
      for (var i = 1; i < roleData.length; i++) {
        if (isActive(roleData[i][roleActiveIdx])) {
          dropdowns.roles.push({ code: roleData[i][roleCodeIdx], name: roleData[i][roleNameIdx] });
        }
      }
    }
  } catch (e) { console.warn('Failed to load roles:', e); }
  
  return dropdowns;
}

/**
 * Get permissions fresh from Firestore (bypasses cache)
 */
function getPermissionsFresh(roleCode) {
  if (!roleCode) return {};
  const permissions = {};
  try {
    var data = getSheetData(SHEETS.PERMISSIONS);
    if (data && data.length > 1) {
      var headers = data[0];
      var roleIdx = headers.indexOf('role_code');
      var moduleIdx = headers.indexOf('module');
      var createIdx = headers.indexOf('can_create');
      var readIdx = headers.indexOf('can_read');
      var updateIdx = headers.indexOf('can_update');
      var deleteIdx = headers.indexOf('can_delete');
      var approveIdx = headers.indexOf('can_approve');
      var exportIdx = headers.indexOf('can_export');
      var fieldRestIdx = headers.indexOf('field_restrictions');
      for (var i = 1; i < data.length; i++) {
        if (data[i][roleIdx] === roleCode) {
          var module = data[i][moduleIdx];
          permissions[module] = {
            can_create: isActive(data[i][createIdx]),
            can_read: isActive(data[i][readIdx]),
            can_update: isActive(data[i][updateIdx]),
            can_delete: isActive(data[i][deleteIdx]),
            can_approve: isActive(data[i][approveIdx]),
            can_export: isActive(data[i][exportIdx]),
            field_restrictions: fieldRestIdx >= 0 ? parseStringArray(data[i][fieldRestIdx]) : []
          };
        }
      }
    }
  } catch (e) { console.warn('Failed to load permissions:', e); }
  return permissions;
}

function getRoleNameFresh(roleCode) {
  if (!roleCode) return '';
  try {
    var data = getSheetData(SHEETS.ROLES);
    if (data && data.length > 1) {
      var headers = data[0];
      var codeIdx = headers.indexOf('role_code');
      var nameIdx = headers.indexOf('role_name');
      for (var i = 1; i < data.length; i++) {
        if (data[i][codeIdx] === roleCode) return data[i][nameIdx] || roleCode;
      }
    }
  } catch (e) { console.warn('Failed to get role name:', e); }
  return roleCode;
}

function getConfigValueFresh(key) {
  if (!key) return null;
  try {
    var data = getSheetData(SHEETS.CONFIG);
    if (data && data.length > 1) {
      var headers = data[0];
      var keyIdx = headers.indexOf('config_key');
      var valueIdx = headers.indexOf('config_value');
      for (var i = 1; i < data.length; i++) {
        if (data[i][keyIdx] === key) return data[i][valueIdx];
      }
    }
  } catch (e) { console.warn('Failed to get config value:', e); }
  return null;
}

/**
 * Quick cache status check
 */
function getCacheStatus() {
  const cache = CacheService.getScriptCache();
  const status = { timestamp: new Date().toISOString(), items: {} };
  
  const keysToCheck = [
    'dropdown_data_all', 'config_SYSTEM_NAME',
    'perm_SUPER_ADMIN', 'perm_SENIOR_AUDITOR', 'perm_JUNIOR_STAFF', 'perm_AUDITEE',
    'role_name_SUPER_ADMIN'
  ];
  
  keysToCheck.forEach(key => {
    status.items[key] = cache.get(key) ? 'CACHED' : 'MISS';
  });
  
  const values = Object.values(status.items);
  status.summary = {
    total: values.length,
    hits: values.filter(v => v === 'CACHED').length,
    misses: values.filter(v => v === 'MISS').length
  };
  status.summary.hitRate = Math.round((status.summary.hits / status.summary.total) * 100) + '%';
  
  console.log('Cache status:', JSON.stringify(status, null, 2));
  return status;
}

/**
 * Clear in-memory sheet data cache for a specific sheet or all sheets.
 * Call after any write operation to ensure subsequent reads return fresh data.
 */
function clearCache(sheetName) {
  if (sheetName) {
    delete _sheetDataCache[sheetName];
  } else {
    _sheetDataCache = {};
  }
}

/**
 * Force clear all caches (CacheService + in-memory)
 */
function clearAllCachesForced() {
  const cache = CacheService.getScriptCache();
  
  const allKeys = [
    'dropdown_data_all', 'config_SYSTEM_NAME', 'config_SESSION_TIMEOUT_HOURS',
    'config_PASSWORD_MIN_LENGTH', 'config_MAX_LOGIN_ATTEMPTS', 'config_AUDIT_FILES_FOLDER_ID'
  ];
  
  const roles = ['SUPER_ADMIN', 'SENIOR_AUDITOR', 'JUNIOR_STAFF', 'AUDITEE', 'MANAGEMENT', 'SENIOR_MGMT'];
  roles.forEach(role => {
    allKeys.push('perm_' + role);
    allKeys.push('role_name_' + role);
  });
  
  let cleared = 0;
  allKeys.forEach(key => {
    try { cache.remove(key); cleared++; } catch (e) {}
  });
  
  // Also clear in-memory cache
  clearCache();
  
  console.log('Cleared', cleared, 'cache keys');
  return { success: true, cleared: cleared };
}

/**
 * Scheduled cache refresh (call via trigger every 6 hours)
 */
function scheduledCacheRefresh() {
  console.log('Scheduled cache refresh starting...');
  try {
    const status = getCacheStatus();
    if (status.summary.hits < status.summary.total / 2) {
      warmAllCachesOnDeploy();
    } else {
      const cache = CacheService.getScriptCache();
      const dropdowns = getDropdownDataFresh();
      cache.put('dropdown_data_all', JSON.stringify(dropdowns), 1800);
      const systemName = getConfigValueFresh('SYSTEM_NAME');
      if (systemName) cache.put('config_SYSTEM_NAME', systemName, 3600);
      console.log('Critical caches refreshed');
    }
    return { success: true };
  } catch (e) {
    console.error('Scheduled cache refresh failed:', e);
    return { success: false, error: e.message };
  }
}

/**
 * Setup cache warming trigger
 */
function setupCacheWarmingTrigger() {
  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(trigger => {
    if (trigger.getHandlerFunction() === 'scheduledCacheRefresh' ||
        trigger.getHandlerFunction() === 'warmAllCachesOnDeploy') {
      ScriptApp.deleteTrigger(trigger);
    }
  });
  ScriptApp.newTrigger('scheduledCacheRefresh').timeBased().everyHours(6).create();
  console.log('Cache warming trigger configured (every 6 hours)');
  return { success: true };
}

/**
 * One-time setup after deployment (Firestore-only mode)
 */
function postDeploymentSetup() {
  console.log('=== POST-DEPLOYMENT SETUP ===');
  
  // 1. Warm all caches
  console.log('[1/2] Warming caches...');
  try { warmAllCachesOnDeploy(); } catch (e) { console.error('Cache warming failed:', e); }
  
  // 2. Setup triggers
  console.log('[2/2] Setting up triggers...');
  try {
    setupAllTriggers();
    setupCacheWarmingTrigger();
  } catch (e) { console.error('Trigger setup failed:', e); }
  
  console.log('=== POST-DEPLOYMENT SETUP COMPLETE ===');
  return { success: true };
}
