/**
 * Main getPermissions function - called by other services
 * Uses short cache TTL to ensure permission changes propagate quickly
 */
function getPermissions(roleCode, forceFresh) {
  if (!roleCode) return {};
  
  // If forceFresh is true, skip cache entirely
  if (forceFresh === true) {
    return getPermissionsFresh(roleCode);
  }
  
  // Try cache first with short TTL (5 minutes)
  const cache = CacheService.getScriptCache();
  const cacheKey = 'perm_' + roleCode;
  
  try {
    const cached = cache.get(cacheKey);
    if (cached) {
      const parsed = JSON.parse(cached);
      if (Object.keys(parsed).length > 0) {
        return parsed;
      }
    }
  } catch (e) {
    console.warn('Cache read failed for permissions:', e);
  }
  
  // Cache miss - read fresh from database
  const permissions = getPermissionsFresh(roleCode);
  
  // Cache for 5 minutes only (300 seconds) to ensure changes propagate
  try {
    if (Object.keys(permissions).length > 0) {
      cache.put(cacheKey, JSON.stringify(permissions), 300);
    }
  } catch (e) {
    console.warn('Failed to cache permissions:', e);
  }
  
  return permissions;
}

/**
 * Check if a role has permission for a specific action on a module
 * @param {string} roleCode - The role code (e.g., 'SUPER_ADMIN')
 * @param {string} module - The module name (e.g., 'WORK_PAPER', 'CONFIG', 'REPORT')
 * @param {string} action - The action (e.g., 'create', 'read', 'update', 'delete', 'approve', 'export')
 * @returns {boolean} - True if permission granted
 */
function checkPermission(roleCode, module, action) {
  if (!roleCode || !module || !action) return false;
  
  const permissions = getPermissions(roleCode);
  
  // Map action to permission field
  const actionMap = {
    'create': 'can_create',
    'read': 'can_read',
    'update': 'can_update',
    'delete': 'can_delete',
    'approve': 'can_approve',
    'export': 'can_export'
  };
  
  const permField = actionMap[action.toLowerCase()];
  if (!permField) return false;
  
  // Check module permissions
  if (permissions[module] && permissions[module][permField] === true) {
    return true;
  }
  
  return false;
}

/**
 * Master cache warm function - call after deployment or when caches are cold
 * Can be run manually from Apps Script editor or via trigger
 */
function warmAllCachesOnDeploy() {
  const startTime = new Date().getTime();
  console.log('===========================================');
  console.log('=== CACHE WARMING STARTED ===');
  console.log('Timestamp:', new Date().toISOString());
  console.log('===========================================');
  
  const cache = CacheService.getScriptCache();
  const results = {
    success: true,
    cached: [],
    errors: [],
    duration: 0
  };
  
  // 1. Warm dropdown data (affiliates, audit areas, users, roles)
  console.log('\n[1/6] Caching dropdown data...');
  try {
    const dropdownStart = new Date().getTime();
    const dropdowns = getDropdownDataFresh();
    cache.put('dropdown_data_all', JSON.stringify(dropdowns), 1800); // 30 min
    results.cached.push('dropdowns (' + (new Date().getTime() - dropdownStart) + 'ms)');
    console.log('✓ Dropdowns cached');
  } catch (e) {
    results.errors.push('dropdowns: ' + e.message);
    console.error('✗ Dropdown caching failed:', e);
  }
  
  // 2. Warm role permissions
  console.log('\n[2/6] Caching role permissions...');
  const roles = ['SUPER_ADMIN', 'SENIOR_AUDITOR', 'JUNIOR_STAFF', 'AUDITEE', 'MANAGEMENT', 'SENIOR_MGMT'];
  try {
    const permStart = new Date().getTime();
    roles.forEach(role => {
      const perms = getPermissionsFresh(role);
      cache.put('perm_' + role, JSON.stringify(perms), 1800);
    });
    results.cached.push('permissions (' + (new Date().getTime() - permStart) + 'ms)');
    console.log('✓ Permissions cached for', roles.length, 'roles');
  } catch (e) {
    results.errors.push('permissions: ' + e.message);
    console.error('✗ Permission caching failed:', e);
  }
  
  // 3. Warm role names
  console.log('\n[3/6] Caching role names...');
  try {
    const roleStart = new Date().getTime();
    roles.forEach(role => {
      const name = getRoleNameFresh(role);
      cache.put('role_name_' + role, name || role, 3600);
    });
    results.cached.push('roleNames (' + (new Date().getTime() - roleStart) + 'ms)');
    console.log('✓ Role names cached');
  } catch (e) {
    results.errors.push('roleNames: ' + e.message);
    console.error('✗ Role name caching failed:', e);
  }
  
  // 4. Warm config values
  console.log('\n[4/6] Caching config values...');
  const configKeys = [
    'SYSTEM_NAME', 
    'SESSION_TIMEOUT_HOURS', 
    'PASSWORD_MIN_LENGTH',
    'MAX_LOGIN_ATTEMPTS',
    'AUDIT_FILES_FOLDER_ID'
  ];
  try {
    const configStart = new Date().getTime();
    configKeys.forEach(key => {
      const value = getConfigValueFresh(key);
      if (value) {
        cache.put('config_' + key, String(value), 3600);
      }
    });
    results.cached.push('config (' + (new Date().getTime() - configStart) + 'ms)');
    console.log('✓ Config values cached');
  } catch (e) {
    results.errors.push('config: ' + e.message);
    console.error('✗ Config caching failed:', e);
  }
  
  // 5. Warm sheet headers (used frequently for column lookups)
  console.log('\n[5/6] Caching sheet headers...');
  const sheetNames = ['USERS', 'WORK_PAPERS', 'ACTION_PLANS', 'SESSIONS'];
  try {
    const headerStart = new Date().getTime();
    sheetNames.forEach(sheetKey => {
      try {
        var sheetName = SHEETS[sheetKey];
        if (sheetName) {
          var sheetData = getSheetData(sheetName);
          if (sheetData && sheetData.length > 0) {
            cache.put('headers_' + sheetKey, JSON.stringify(sheetData[0]), 3600);
          }
        }
      } catch (e) {
        console.warn('Header cache failed for', sheetKey, ':', e.message);
      }
    });
    results.cached.push('headers (' + (new Date().getTime() - headerStart) + 'ms)');
    console.log('✓ Sheet headers cached');
  } catch (e) {
    results.errors.push('headers: ' + e.message);
    console.error('✗ Header caching failed:', e);
  }
  
  // 6. Verify indexes are built
  console.log('\n[6/6] Verifying indexes...');
  try {
    const indexStart = new Date().getTime();
    let indexesOk = true;
    
    // Check user index
    const userIndexSheet = getSheet(SHEETS.INDEX_USERS);
    if (!userIndexSheet || userIndexSheet.getLastRow() < 2) {
      console.log('User index empty, rebuilding...');
      Index.rebuild('USER');
      indexesOk = false;
    }
    
    // Check work paper index
    const wpIndexSheet = getSheet(SHEETS.INDEX_WORK_PAPERS);
    if (!wpIndexSheet || wpIndexSheet.getLastRow() < 2) {
      console.log('Work paper index empty, rebuilding...');
      Index.rebuild('WORK_PAPER');
      indexesOk = false;
    }
    
    // Check action plan index
    const apIndexSheet = getSheet(SHEETS.INDEX_ACTION_PLANS);
    if (!apIndexSheet || apIndexSheet.getLastRow() < 2) {
      console.log('Action plan index empty, rebuilding...');
      Index.rebuild('ACTION_PLAN');
      indexesOk = false;
    }
    
    if (indexesOk) {
      results.cached.push('indexes verified (' + (new Date().getTime() - indexStart) + 'ms)');
      console.log('✓ All indexes verified');
    } else {
      results.cached.push('indexes rebuilt (' + (new Date().getTime() - indexStart) + 'ms)');
      console.log('✓ Indexes rebuilt');
    }
  } catch (e) {
    results.errors.push('indexes: ' + e.message);
    console.error('✗ Index verification failed:', e);
  }
  
  // Summary
  results.duration = new Date().getTime() - startTime;
  
  console.log('\n===========================================');
  console.log('=== CACHE WARMING COMPLETE ===');
  console.log('Duration:', results.duration, 'ms');
  console.log('Cached:', results.cached.length, 'categories');
  console.log('Errors:', results.errors.length);
  if (results.errors.length > 0) {
    console.log('Error details:', results.errors);
  }
  console.log('===========================================');
  
  return results;
}

/**
 * Get dropdown data fresh from database (bypasses cache)
 */
