/**
 * Get permissions fresh from database (bypasses cache)
 */
function getPermissionsFresh(roleCode) {
  if (!roleCode) return {};
  
  const permissions = {};
  
  try {
    var data = getSheetData(SHEETS.PERMISSIONS);
    if (data && data.length > 1) {
      var headers = data[0];
      var roleIdx = headers.indexOf('role_code');
      var moduleIdx = headers.indexOf('module');
      var createIdx = headers.indexOf('can_create');
      var readIdx = headers.indexOf('can_read');
      var updateIdx = headers.indexOf('can_update');
      var deleteIdx = headers.indexOf('can_delete');
      var approveIdx = headers.indexOf('can_approve');
      var exportIdx = headers.indexOf('can_export');
      var fieldRestIdx = headers.indexOf('field_restrictions');

      for (var i = 1; i < data.length; i++) {
        if (data[i][roleIdx] === roleCode) {
          var module = data[i][moduleIdx];
          permissions[module] = {
            can_create: isActive(data[i][createIdx]),
            can_read: isActive(data[i][readIdx]),
            can_update: isActive(data[i][updateIdx]),
            can_delete: isActive(data[i][deleteIdx]),
            can_approve: isActive(data[i][approveIdx]),
            can_export: isActive(data[i][exportIdx]),
            field_restrictions: fieldRestIdx >= 0 ? parseStringArray(data[i][fieldRestIdx]) : []
          };
        }
      }
    }
  } catch (e) {
    console.warn('Failed to load permissions:', e);
  }
  
  return permissions;
}

/**
 * Get role name fresh from database (bypasses cache)
 */
function getRoleNameFresh(roleCode) {
  if (!roleCode) return '';
  
  try {
    var data = getSheetData(SHEETS.ROLES);
    if (data && data.length > 1) {
      var headers = data[0];
      var codeIdx = headers.indexOf('role_code');
      var nameIdx = headers.indexOf('role_name');

      for (var i = 1; i < data.length; i++) {
        if (data[i][codeIdx] === roleCode) {
          return data[i][nameIdx] || roleCode;
        }
      }
    }
  } catch (e) {
    console.warn('Failed to get role name:', e);
  }
  
  return roleCode;
}

/**
 * Get config value fresh from database (bypasses cache)
 */
function getConfigValueFresh(key) {
  if (!key) return null;
  
  try {
    var data = getSheetData(SHEETS.CONFIG);
    if (data && data.length > 1) {
      var headers = data[0];
      var keyIdx = headers.indexOf('config_key');
      var valueIdx = headers.indexOf('config_value');

      for (var i = 1; i < data.length; i++) {
        if (data[i][keyIdx] === key) {
          return data[i][valueIdx];
        }
      }
    }
  } catch (e) {
    console.warn('Failed to get config value:', e);
  }
  
  return null;
}

/**
 * Quick cache status check
 */
function getCacheStatus() {
  const cache = CacheService.getScriptCache();
  const status = {
    timestamp: new Date().toISOString(),
    items: {}
  };
  
  // Check key cache items
  const keysToCheck = [
    'dropdown_data_all',
    'config_SYSTEM_NAME',
    'perm_SUPER_ADMIN',
    'perm_SENIOR_AUDITOR',
    'perm_JUNIOR_STAFF',
    'perm_AUDITEE',
    'role_name_SUPER_ADMIN',
    'headers_USERS',
    'headers_WORK_PAPERS'
  ];
  
  keysToCheck.forEach(key => {
    const value = cache.get(key);
    status.items[key] = value ? 'CACHED' : 'MISS';
  });
  
  // Count hits and misses
  const values = Object.values(status.items);
  status.summary = {
    total: values.length,
    hits: values.filter(v => v === 'CACHED').length,
    misses: values.filter(v => v === 'MISS').length
  };
  status.summary.hitRate = Math.round((status.summary.hits / status.summary.total) * 100) + '%';
  
  console.log('Cache status:', JSON.stringify(status, null, 2));
  return status;
}

/**
 * Force clear all caches
 */
function clearAllCachesForced() {
  const cache = CacheService.getScriptCache();
  
  // All known cache keys
  const allKeys = [
    'dropdown_data_all',
    'config_SYSTEM_NAME',
    'config_SESSION_TIMEOUT_HOURS',
    'config_PASSWORD_MIN_LENGTH',
    'config_MAX_LOGIN_ATTEMPTS',
    'config_AUDIT_FILES_FOLDER_ID',
    'headers_USERS',
    'headers_WORK_PAPERS',
    'headers_ACTION_PLANS',
    'headers_SESSIONS'
  ];
  
  // Add role-based keys
  const roles = ['SUPER_ADMIN', 'SENIOR_AUDITOR', 'JUNIOR_STAFF', 'AUDITEE', 'MANAGEMENT', 'SENIOR_MGMT'];
  roles.forEach(role => {
    allKeys.push('perm_' + role);
    allKeys.push('role_name_' + role);
  });
  
  // Clear all
  let cleared = 0;
  allKeys.forEach(key => {
    try {
      cache.remove(key);
      cleared++;
    } catch (e) {}
  });
  
  console.log('Cleared', cleared, 'cache keys');
  return { success: true, cleared: cleared };
}

/**
 * Scheduled cache refresh (call via trigger every 6 hours)
 */
function scheduledCacheRefresh() {
  console.log('Scheduled cache refresh starting...');
  
  try {
    // Check cache status first
    const status = getCacheStatus();
    
    // Only warm if hit rate is below 50%
    if (status.summary.hits < status.summary.total / 2) {
      console.log('Cache hit rate low (' + status.summary.hitRate + '), warming caches...');
      warmAllCachesOnDeploy();
    } else {
      console.log('Cache hit rate acceptable (' + status.summary.hitRate + '), skipping full warm');
      
      // Just refresh the most critical caches
      const cache = CacheService.getScriptCache();
      
      // Refresh dropdowns
      const dropdowns = getDropdownDataFresh();
      cache.put('dropdown_data_all', JSON.stringify(dropdowns), 1800);
      
      // Refresh config
      const systemName = getConfigValueFresh('SYSTEM_NAME');
      if (systemName) {
        cache.put('config_SYSTEM_NAME', systemName, 3600);
      }
      
      console.log('Critical caches refreshed');
    }
    
    return { success: true };
    
  } catch (e) {
    console.error('Scheduled cache refresh failed:', e);
    return { success: false, error: e.message };
  }
}

/**
 * Performance test - measures time for common operations
 */
function runPerformanceTest() {
  console.log('=== PERFORMANCE TEST ===');
  const results = {};
  
  // Test 1: Cold dropdown load
  clearAllCachesForced();
  let start = new Date().getTime();
  getDropdownDataFresh();
  results.dropdownCold = new Date().getTime() - start;
  console.log('Dropdown (cold):', results.dropdownCold, 'ms');
  
  // Test 2: Warm dropdown load
  warmAllCachesOnDeploy();
  start = new Date().getTime();
  const cache = CacheService.getScriptCache();
  JSON.parse(cache.get('dropdown_data_all'));
  results.dropdownWarm = new Date().getTime() - start;
  console.log('Dropdown (warm):', results.dropdownWarm, 'ms');
  
  // Test 3: Permission load (cold)
  cache.remove('perm_SUPER_ADMIN');
  start = new Date().getTime();
  getPermissionsFresh('SUPER_ADMIN');
  results.permissionCold = new Date().getTime() - start;
  console.log('Permission (cold):', results.permissionCold, 'ms');
  
  // Test 4: Permission load (warm)
  cache.put('perm_SUPER_ADMIN', JSON.stringify(getPermissionsFresh('SUPER_ADMIN')), 1800);
  start = new Date().getTime();
  JSON.parse(cache.get('perm_SUPER_ADMIN'));
  results.permissionWarm = new Date().getTime() - start;
  console.log('Permission (warm):', results.permissionWarm, 'ms');
  
  // Summary
  console.log('\n=== SUMMARY ===');
  console.log('Dropdown speedup:', Math.round(results.dropdownCold / Math.max(results.dropdownWarm, 1)) + 'x');
  console.log('Permission speedup:', Math.round(results.permissionCold / Math.max(results.permissionWarm, 1)) + 'x');
  
  return results;
}

/**
 * Setup cache warming trigger
 */
function setupCacheWarmingTrigger() {
  // Remove existing cache warming triggers
  const triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(trigger => {
    if (trigger.getHandlerFunction() === 'scheduledCacheRefresh' || 
        trigger.getHandlerFunction() === 'warmAllCachesOnDeploy') {
      ScriptApp.deleteTrigger(trigger);
    }
  });
  
  // Create new trigger - every 6 hours
  ScriptApp.newTrigger('scheduledCacheRefresh')
    .timeBased()
    .everyHours(6)
    .create();
  
  console.log('Cache warming trigger configured (every 6 hours)');
  return { success: true };
}

