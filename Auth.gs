<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Hass Petroleum Audit Tracker - Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <!-- Materialize CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body class="grey lighten-4">
  <!-- Login Content -->
  <div class="container">
    <div class="row" style="margin-top: 100px;">
      <div class="col s12 m6 offset-m3">
        <div class="card">
          <div class="card-content center">
            <!-- Corporate Logo -->
            <img src="logo.png" alt="Hass Petroleum Logo" class="responsive-img" style="height: 100px; margin-bottom: 20px;">
            <span class="card-title">Hass Petroleum Audit Tracker</span>
            <p>Please login using your corporate account (email ending with @hasspetroleum.com).</p>
          </div>
          <div class="card-action center">
            <a id="login-button" class="btn blue darken-4 waves-effect waves-light">Login with Google</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Materialize JS (for any interactive components) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>
